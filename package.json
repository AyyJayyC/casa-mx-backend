{
  "name": "casa-mx-backend",
  "version": "1.0.0",
  "description": "CASA MX Backend API - Phase 4",
  "type": "module",
  "engines": {
    "node": ">=18 <=20"
  },
  "main": "dist/server.js",
  "scripts": {
    "dev": "node scripts/check-node-version.js && tsx watch src/server.ts",
    "build": "node scripts/check-node-version.js && tsc && node scripts/copy-static-assets.js && prisma generate",
    "start": "npx prisma migrate deploy && node dist/server.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "check-env": "tsx scripts/check-env.ts",
    "prisma:migrate": "prisma migrate dev",
    "prisma:generate": "prisma generate",
    "prisma:seed": "tsx prisma/seed.ts",
    "prisma:studio": "prisma studio"
  },
  "keywords": [
    "fastify",
    "typescript",
    "prisma",
    "postgresql"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1035.0",
    "@aws-sdk/s3-request-presigner": "^3.1035.0",
    "@fastify/cookie": "^11.0.2",
    "@fastify/cors": "^11.2.0",
    "@fastify/helmet": "^13.0.2",
    "@fastify/multipart": "^10.0.0",
    "@fastify/rate-limit": "^10.3.0",
    "@prisma/client": "^5.19.0",
    "@sendgrid/mail": "^8.1.6",
    "@types/pdfkit": "^0.17.6",
    "bcrypt": "^6.0.0",
    "dotenv": "^16.4.5",
    "fastify": "^5.8.2",
    "ioredis": "^5.10.1",
    "jsonwebtoken": "^9.0.2",
    "pdfkit": "^0.18.0",
    "pino": "^9.3.2",
    "pino-pretty": "^11.2.2",
    "stripe": "^22.0.2",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^22.5.0",
    "prisma": "^5.19.0",
    "tsx": "^4.19.0",
    "typescript": "^5.5.4",
    "vitest": "^2.0.5"
  }
}
