# Application Environment
NODE_ENV=development
PORT=3001

# Database Configuration
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
# ⚠️ REQUIRED: Must be valid PostgreSQL connection string
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/casamx?schema=public"

# Redis Configuration (Optional but recommended for caching)
# Format: redis://HOST:PORT or redis://USER:PASSWORD@HOST:PORT
# ⚠️ OPTIONAL: Leave blank to disable caching, falls back to direct DB queries
REDIS_URL=redis://localhost:6379

# JWT Authentication
# ⚠️ REQUIRED: Use openssl rand -base64 32 to generate secure random string (min 32 chars)
# ⚠️ PRODUCTION: MUST change from default value
JWT_SECRET=your-secret-key-change-in-production
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d
# ⚠️ OPTIONAL: Separate secret for refresh tokens (recommended for production)
JWT_REFRESH_SECRET=your-refresh-secret-change-in-production

# Frontend Configuration
# ⚠️ REQUIRED: Frontend URL for CORS configuration
# ⚠️ PRODUCTION: Must be your actual domain (e.g., https://casamx.com)
FRONTEND_URL=http://localhost:3000

# Google Maps API
# ⚠️ REQUIRED: Get API key from https://console.cloud.google.com/apis/credentials
# ⚠️ PRODUCTION: Enable restrictions (HTTP referrers, API quotas)
MAPS_API_KEY=AIza...your-google-maps-api-key-here
# Cost safety: keep false to avoid billable Google Maps requests.
# Set to true only when you intentionally want to use paid Google Maps endpoints.
ENABLE_BILLABLE_MAPS=false

# Document Encryption (Phase 1)
# ⚠️ PRODUCTION: Generate with: openssl rand -hex 32
# ⚠️ OPTIONAL in dev/test: derived from JWT_SECRET if not set
DOCUMENT_ENCRYPTION_KEY=

# AWS S3 (Phase 1 - Document Storage)
# ⚠️ OPTIONAL in dev/test: uploads are stubbed when credentials are absent
AWS_ACCESS_KEY_ID=your-aws-access-key-id
AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key
AWS_S3_BUCKET=casa-mx-documents
AWS_REGION=us-east-1

# Stripe (Phase 3 - Credit System)
# ⚠️ OPTIONAL in dev/test: use Stripe test keys (sk_test_...)
STRIPE_SECRET_KEY=sk_test_your_test_key_here

# SendGrid (Phase 1 - Email Verification)
# ⚠️ OPTIONAL in dev/test
SENDGRID_API_KEY=SG.your-sendgrid-api-key-here

# Optional: Monitoring & Error Tracking (Uncomment to enable)
# SENTRY_DSN=https://...your-sentry-dsn...
# LOGR_OCKET_APP_ID=...your-logrocket-id...
# DATADOG_API_KEY=...your-datadog-key...
