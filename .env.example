# Application Environment
NODE_ENV=development
PORT=3001

# Database Configuration
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
# ⚠️ REQUIRED: Must be valid PostgreSQL connection string
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/casamx?schema=public"

# Redis Configuration (Optional but recommended for caching)
# Format: redis://HOST:PORT or redis://USER:PASSWORD@HOST:PORT
# ⚠️ OPTIONAL: Leave blank to disable caching, falls back to direct DB queries
REDIS_URL=redis://localhost:6379

# JWT Authentication
# ⚠️ REQUIRED: Use openssl rand -base64 32 to generate secure random string (min 32 chars)
# ⚠️ PRODUCTION: MUST change from default value
JWT_SECRET=your-secret-key-change-in-production
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d
# ⚠️ OPTIONAL: Separate secret for refresh tokens (recommended for production)
JWT_REFRESH_SECRET=your-refresh-secret-change-in-production

# Frontend Configuration
# ⚠️ REQUIRED: Frontend URL for CORS configuration
# ⚠️ PRODUCTION: Must be your actual domain (e.g., https://casamx.com)
FRONTEND_URL=http://localhost:3000

# Google Maps API
# ⚠️ REQUIRED: Get API key from https://console.cloud.google.com/apis/credentials
# ⚠️ PRODUCTION: Enable restrictions (HTTP referrers, API quotas)
MAPS_API_KEY=AIza...your-google-maps-api-key-here
# Cost safety: keep false to avoid billable Google Maps requests.
# Set to true only when you intentionally want to use paid Google Maps endpoints.
ENABLE_BILLABLE_MAPS=false

# ── Credits & Payments (Stripe) ───────────────────────────────────────────────
# ⚠️ OPTIONAL: Configure to enable real credit purchases via Stripe
# Get keys from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_...your-stripe-secret-key
STRIPE_WEBHOOK_SECRET=whsec_...your-stripe-webhook-secret

# ── Document Encryption ───────────────────────────────────────────────────────
# ⚠️ RECOMMENDED: 32-byte (64 hex chars) key for AES-256-CBC document encryption
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# If omitted, documents are stored WITHOUT encryption (not recommended for production)
DOCUMENT_ENCRYPTION_KEY=your-64-char-hex-encryption-key-here

# Directory where uploaded documents are stored (relative or absolute path)
UPLOAD_DIR=./uploads

# ── Social OAuth ──────────────────────────────────────────────────────────────
# Google OAuth - https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Facebook Login - https://developers.facebook.com/apps/
FACEBOOK_APP_ID=your-facebook-app-id
FACEBOOK_APP_SECRET=your-facebook-app-secret

# Apple Sign In - https://developer.apple.com/account/resources/identifiers/list/serviceId
APPLE_CLIENT_ID=com.casamx.app

# Optional: Monitoring & Error Tracking (Uncomment to enable)
# SENTRY_DSN=https://...your-sentry-dsn...
# LOGR_OCKET_APP_ID=...your-logrocket-id...
# DATADOG_API_KEY=...your-datadog-key...
